# ─────────────────────────────────────────────────────────────────────────────
# TRADEMAN — Environment Variables Template
# Copy to .env and fill in your values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Broker Adapter ────────────────────────────────────────────────────────────
# Options: mock | openalgo
BROKER_ADAPTER=mock

# OpenAlgo connection (only needed when BROKER_ADAPTER=openalgo)
OPENALGO_HOST=localhost:5000
OPENALGO_WS_HOST=localhost:8765
OPENALGO_API_KEY=your-openalgo-api-key-here

# ── Database ──────────────────────────────────────────────────────────────────
# Dev default: SQLite (no setup required)
DATABASE_URL=sqlite+aiosqlite:///./trademan.db

# Production: TimescaleDB / PostgreSQL
# DATABASE_URL=postgresql+asyncpg://trademan:password@localhost:5432/trademan

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Market Data ───────────────────────────────────────────────────────────────
# Poll interval in seconds (used by mock adapter)
LTP_POLL_INTERVAL_SECONDS=0.5

# How many seconds before LTP data is considered stale
LTP_STALE_THRESHOLD_SECONDS=5.0

# Set to true to archive every raw tick to TimescaleDB ltp_ticks hypertable
STORE_TICKS=false

# ── MTM Tracking ─────────────────────────────────────────────────────────────
# Interval in seconds between MTM snapshots saved to TimescaleDB
MTM_SNAPSHOT_INTERVAL_SECONDS=15.0

# ── Warmup ────────────────────────────────────────────────────────────────────
# How to warm up the LTP cache on startup
# Options: none | db (load last candle close from DB) | openalgo (fetch live)
WARMUP_SOURCE=none

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
DEBUG=true

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Integrations (optional) ───────────────────────────────────────────────────
# Telegram bot token for alert delivery
TELEGRAM_BOT_TOKEN=

# Generic webhook URL for alert delivery
WEBHOOK_URL=
